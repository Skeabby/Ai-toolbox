# ──────────────────────────────────────────────────────────────────────────────
#  .env.local.example
#
#  Copy this file to .env.local and fill in every value.
#  NEVER commit .env.local to Git — it's already in .gitignore.
#
#  Setup guide:
#    1. cp .env.local.example .env.local
#    2. Fill in each variable (instructions in comments below)
#    3. Restart your dev server: npm run dev
# ──────────────────────────────────────────────────────────────────────────────


# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
#
# NEXT_PUBLIC_ prefix = safe to expose to the browser (public key only)
# SUPABASE_SERVICE_ROLE_KEY = server-only, never prefix with NEXT_PUBLIC_

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Google Gemini (Primary AI — free tier) ─────────────────────────────────────
# Free tier: 15 RPM · 1,000,000 tokens/day · no credit card needed
#
# Get your key: https://aistudio.google.com/app/apikey
#   1. Sign in with a Google account
#   2. Click "Create API Key"
#   3. Copy the key here
#
# IMPORTANT: This is a SERVER-ONLY variable (no NEXT_PUBLIC_ prefix).
# It is used exclusively in API routes — never sent to the browser.

GEMINI_API_KEY=AIzaSy...


# ── Groq (Fallback AI — free tier) ────────────────────────────────────────────
# Optional. Use as a fallback if Gemini quota is exhausted.
# Free tier: ~14,400 req/day on Llama 3.1 70B
#
# Get your key: https://console.groq.com → API Keys → Create

GROQ_API_KEY=gsk_...


# ── App config ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Survival Toolkit


# ──────────────────────────────────────────────────────────────────────────────
#  VERCEL DEPLOYMENT
#
#  When deploying to Vercel, add these same variables in:
#    Vercel Dashboard → your project → Settings → Environment Variables
#
#  Set NEXT_PUBLIC_APP_URL to your production URL, e.g.:
#    NEXT_PUBLIC_APP_URL=https://ai-survival-toolkit.vercel.app
#
#  Vercel will automatically inject them into your build.
# ──────────────────────────────────────────────────────────────────────────────
